package org.firstinspires.ftc.teamcode;

import com.qualcomm.robotcore.hardware.DcMotor;
import com.qualcomm.robotcore.hardware.HardwareMap;
import com.qualcomm.robotcore.hardware.Servo;

/**
 * Esta clase centraliza la configuración de hardware del Starter Bot de Copa Kai.
 * DIRECCIONES CORREGIDAS: Para que el chasis marche recto en modo Arcade.
 */
public class ManualHardware {

    /* Componentes públicos accesibles por los OpModes */
    public DcMotor m1 = null; // Motor Izquierdo (Rueda - Puerto 0)
    public DcMotor m2 = null; // Motor Derecho (Rueda - Puerto 1)
    public DcMotor m3 = null; // Motor Superior Disparador (Rueda Alta Velocidad - Puerto 3)
    public Servo   servoKit = null;  // Servo Gatillo Izquierdo (Puerto 0 Servos)
    public Servo   servoKit2 = null; // Servo Gatillo Derecho (Puerto 1 Servos)

    /* Constantes de calibración para el Disparador en Servo Mode */
    public static final double DISPARADOR_RETRAIDO = 0.0; 
    public static final double DISPARADOR_LANZAR   = 0.6; 

    private HardwareMap hwMap = null;

    public ManualHardware() {
    }

    public void init(HardwareMap ahwMap) {
        hwMap = ahwMap;

        // 1. Vincular componentes con la Driver Station
        m1 = hwMap.get(DcMotor.class, "m1");
        m2 = hwMap.get(DcMotor.class, "m2");
        m3 = hwMap.get(DcMotor.class, "m3");
        servoKit = hwMap.get(Servo.class, "servo_kit");
        servoKit2 = hwMap.get(Servo.class, "servo_kit2");

        // 2. CONFIGURACIÓN DE DIRECCIONES CORREGIDA FÍSICAMENTE
        // Cambiamos m1 a FORWARD y m2 a REVERSE para equilibrar las fuerzas y que no se cruce
        m1.setDirection(DcMotor.Direction.FORWARD);  
        m2.setDirection(DcMotor.Direction.REVERSE);  
        
        // El motor de disparo superior y los servos se quedan igual
        m3.setDirection(DcMotor.Direction.FORWARD);
        servoKit.setDirection(Servo.Direction.FORWARD);
        servoKit2.setDirection(Servo.Direction.REVERSE); // Mantiene el modo espejo que ya funcionaba bien

        // 3. Freno electrónico para máxima estabilidad
        m1.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);
        m2.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);
        m3.setZeroPowerBehavior(DcMotor.ZeroPowerBehavior.BRAKE);

        // 4. Estados iniciales seguros
        m1.setPower(0);
        m2.setPower(0);
        m3.setPower(0);
        
        servoKit.setPosition(DISPARADOR_RETRAIDO);
        servoKit2.setPosition(DISPARADOR_RETRAIDO);

        // 5. Modos de motor para TeleOp Arcade
        m1.setMode(DcMotor.RunMode.RUN_WITHOUT_ENCODER);
        m2.setMode(DcMotor.RunMode.RUN_WITHOUT_ENCODER);
    }
}
